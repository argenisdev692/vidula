{
	"info": {
		"name": "Students CRUD",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Students",
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{base_url}}/api/students/admin",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin"],
					"query": [
						{ "key": "page", "value": "1" },
						{ "key": "perPage", "value": "15" },
						{ "key": "search", "value": "", "disabled": true },
						{ "key": "status", "value": "", "disabled": true }
					]
				}
			}
		},
		{
			"name": "Show Student",
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{base_url}}/api/students/admin/{{student_uuid}}",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "{{student_uuid}}"]
				}
			}
		},
		{
			"name": "Create Student",
			"request": {
				"method": "POST",
				"url": {
					"raw": "{{base_url}}/api/students/admin",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin"]
				},
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"+123456789\",\n    \"dni\": \"12345678\",\n    \"birth_date\": \"2000-01-15\",\n    \"address\": \"123 Main St\",\n    \"notes\": \"New student\",\n    \"status\": \"DRAFT\",\n    \"active\": true\n}"
				}
			}
		},
		{
			"name": "Update Student",
			"request": {
				"method": "PUT",
				"url": {
					"raw": "{{base_url}}/api/students/admin/{{student_uuid}}",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "{{student_uuid}}"]
				},
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Jane Doe Updated\",\n    \"phone\": \"+987654321\",\n    \"status\": \"ACTIVE\"\n}"
				}
			}
		},
		{
			"name": "Delete Student",
			"request": {
				"method": "DELETE",
				"url": {
					"raw": "{{base_url}}/api/students/admin/{{student_uuid}}",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "{{student_uuid}}"]
				}
			}
		},
		{
			"name": "Restore Student",
			"request": {
				"method": "PATCH",
				"url": {
					"raw": "{{base_url}}/api/students/admin/{{student_uuid}}/restore",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "{{student_uuid}}", "restore"]
				}
			}
		},
		{
			"name": "Bulk Delete Students",
			"request": {
				"method": "POST",
				"url": {
					"raw": "{{base_url}}/api/students/admin/bulk-delete",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "bulk-delete"]
				},
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"uuids\": [\"uuid-1\", \"uuid-2\"]\n}"
				}
			}
		},
		{
			"name": "Export Students Excel",
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{base_url}}/api/students/admin/export?format=excel",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "export"],
					"query": [{ "key": "format", "value": "excel" }]
				}
			}
		},
		{
			"name": "Export Students PDF",
			"request": {
				"method": "GET",
				"url": {
					"raw": "{{base_url}}/api/students/admin/export?format=pdf",
					"host": ["{{base_url}}"],
					"path": ["api", "students", "admin", "export"],
					"query": [{ "key": "format", "value": "pdf" }]
				}
			}
		}
	]
}
